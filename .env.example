# ============================================================
# Nikko Eco — Variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore — NUNCA lo subas al repo.
# ============================================================

# --- SMTP (IONOS) ------------------------------------------------
# Host SMTP de IONOS para España.
SMTP_HOST=smtp.ionos.es

# Puerto:
#   587 → STARTTLS (recomendado por IONOS)
#   465 → SSL/TLS
SMTP_PORT=587

# Usuario = email completo del buzón emisor (suele ser info@nikkoeco.com).
SMTP_USER=info@nikkoeco.com

# Contraseña del buzón. Cámbiala en el panel de IONOS si se compromete.
SMTP_PASS=

# --- Destinatario ------------------------------------------------
# A quién llegan los mensajes del formulario de contacto.
MAIL_TO=ventas@nikkoeco.com

# Nombre visible como remitente en el email.
MAIL_FROM_NAME=Web Nikko Eco
